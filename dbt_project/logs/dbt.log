  create  table "insightflow"."public"."mart_user_metrics__dbt_tmp"
  
  
    as
  
  (
    SELECT
    user_id,
    MIN(event_time)::date AS first_seen_date,
    MAX(event_time)::date AS last_seen_date,
    COUNT(*) AS total_events,
    COUNT(DISTINCT session_id) AS sessions,
